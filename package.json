{
  "name": "outlook-cli",
  "version": "0.3.1",
  "description": "Local CLI that piggybacks on your existing Outlook Web session to read/search/send mail — no app registration, no admin consent.",
  "keywords": [
    "outlook",
    "owa",
    "office365",
    "cli",
    "playwright",
    "claude-skill"
  ],
  "license": "MIT",
  "homepage": "https://github.com/muhammaddadu/outlook-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muhammaddadu/outlook-cli.git"
  },
  "bugs": {
    "url": "https://github.com/muhammaddadu/outlook-cli/issues"
  },
  "type": "module",
  "bin": {
    "outlook": "./src/cli.mjs"
  },
  "files": [
    "src",
    "skill",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/cli.mjs",
    "test": "node --test test/*.test.mjs",
    "skill:install": "node skill/install.mjs",
    "skill:install:project": "node skill/install.mjs --scope project"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "playwright": "^1.49.0"
  }
}
